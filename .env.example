# ===== 实验组 AI 大模型 API 中转站 配置示例 =====
# 复制为 .env 后按需修改。不提交真实密钥到代码仓库。

APP_NAME=实验组 AI 大模型 API 中转站
ENVIRONMENT=dev

# ---- 数据库 ----
# 默认 SQLite，开箱即用。生产建议 PostgreSQL / MySQL。
DATABASE_URL=sqlite:///./relay.db
# DATABASE_URL=postgresql+psycopg://relay:relay@localhost:5432/relay
# DATABASE_URL=mysql+pymysql://relay:relay@localhost:3306/relay

# ---- 安全（生产务必修改为随机长字符串）----
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_EXPIRE_MINUTES=720
# 真实供应商 Key 的加密口令（Fernet 由此派生），生产必须修改
ENCRYPTION_SECRET=dev-insecure-encryption-secret-change-me

# ---- 平台内部 API Token 前缀 ----
API_TOKEN_PREFIX=sk-relay-

# ---- 初始管理员（首次启动自动创建）----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_EMAIL=admin@example.com

# ---- 计费 ----
BASE_POINTS_PER_1K_TOKENS=1.0
SIGNUP_FREE_POINTS=500

# ---- 网页会话默认限额 ----
DEFAULT_DAILY_REQUEST_LIMIT=200
DEFAULT_RATE_LIMIT_PER_MINUTE=10
DEFAULT_DAILY_TOKEN_LIMIT=200000

# ---- CORS（多个用逗号分隔，* 表示全部）----
CORS_ORIGINS=*

# ===== 真实供应商示例（可选）=====
# MVP 默认内置 mock 供应商，无需任何真实 Key 即可跑通。
# 接入真实 OpenAI 兼容供应商时，用管理员后台或 seed 添加 Key 即可。
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2

# ===== 生产化加固（可选）=====
# 数据库改 PostgreSQL：
# DATABASE_URL=postgresql+psycopg://relay:relay@localhost:5432/relay
# Redis 分布式限流（多实例一致；不配置则进程内限流）：
# REDIS_URL=redis://localhost:6379/0
# 日志：text | json（json 便于 ELK/Loki 采集）
LOG_FORMAT=text
LOG_LEVEL=INFO
# Prometheus 指标开关（/metrics）
METRICS_ENABLED=true
# 机密托管：从挂载文件读取密钥（Vault/KMS/K8s Secret），优先级高于明文
# JWT_SECRET_FILE=/run/secrets/jwt_secret
# ENCRYPTION_SECRET_FILE=/run/secrets/encryption_secret

# ===== 真实学校 SSO（OIDC）=====
# SSO_MODE=oidc
# SSO_CLIENT_ID=relay
# SSO_CLIENT_SECRET=...
# SSO_AUTHORIZE_URL=https://idp.example.edu/oauth2/authorize
# SSO_TOKEN_URL=https://idp.example.edu/oauth2/token
# SSO_USERINFO_URL=https://idp.example.edu/oauth2/userinfo
# SSO_REDIRECT_URI=https://relay.example.edu/sso/callback
